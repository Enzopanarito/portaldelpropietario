{
  "manifest_version": 3,
  "name": "Villas Los Apamates · Conector WhatsApp",
  "version": "1.0.0",
  "description": "Conector local autorizado para ejecutar lotes de mensajería desde el portal administrativo.",
  "minimum_chrome_version": "120",
  "key": "",
  "permissions": [
    "nativeMessaging",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["whatsapp-content.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://villalosapamates.netlify.app/*"
    ]
  },
  "action": {
    "default_title": "Villas Los Apamates · WhatsApp"
  }
}
