{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://villalosapamates.netlify.app/schemas/payment-proof-analysis-v2.json",
  "title": "VLA Payment Proof Analysis V2",
  "description": "Salida de extracción. No constituye aprobación, autenticidad ni decisión de acceso.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "method",
    "bank_or_platform",
    "amount",
    "currency",
    "transaction_date",
    "transaction_time",
    "reference",
    "transaction_status",
    "recipient_name",
    "recipient_phone",
    "recipient_email",
    "recipient_account_visible",
    "memo",
    "confidence",
    "critical_fields_visible",
    "warnings",
    "possible_visual_modification"
  ],
  "properties": {
    "method": {"type":"string","enum":["TRANSFER_VE","MOBILE_PAYMENT_VE","ZELLE","TRANSFER_US","OTHER","UNKNOWN"]},
    "bank_or_platform": {"type":["string","null"],"maxLength":160},
    "amount": {"type":["number","null"],"minimum":0},
    "currency": {"type":"string","enum":["VES","USD","UNKNOWN"]},
    "transaction_date": {"type":["string","null"],"format":"date"},
    "transaction_time": {"type":["string","null"],"pattern":"^(?:[01]\\d|2[0-3]):[0-5]\\d:[0-5]\\d$"},
    "reference": {"type":["string","null"],"maxLength":160},
    "transaction_status": {"type":"string","enum":["COMPLETED","SENT","PROCESSED","PENDING","SCHEDULED","FAILED","CANCELLED","REJECTED","UNKNOWN"]},
    "recipient_name": {"type":["string","null"],"maxLength":200},
    "recipient_phone": {"type":["string","null"],"maxLength":80},
    "recipient_email": {"type":["string","null"],"maxLength":254},
    "recipient_account_visible": {"type":["string","null"],"maxLength":120},
    "memo": {"type":["string","null"],"maxLength":500},
    "confidence": {"type":"number","minimum":0,"maximum":1},
    "critical_fields_visible": {"type":"boolean"},
    "warnings": {"type":"array","maxItems":30,"items":{"type":"string","maxLength":300}},
    "possible_visual_modification": {"type":"boolean"}
  }
}
