-<script>function token(){return sessionStorage.getItem('vla-admin-token')||''}function authHeaders(){return {'Content-Type':'application/json','Authorization':'Bearer '+token()}}function toast(m,err=false){const t=document.getElementById('toast');t.textContent=m;t.className='fixed bottom-5 right-5 toast text-white px-5 py-3 rounded-lg shadow-lg '+(err?'bg-red-600':'bg-green-600');t.classList.remove('opacity-0','translate-y-6');setTimeout(()=>t.classList.add('opacity-0','translate-y-6'),4500)}async function adminFetch(url,opt={}){const r=await fetch(url,{...opt,headers:{...authHeaders(),...(opt.headers||{})}});const d=await r.json().catch(()=>({}));if(r.status===401){sessionStorage.removeItem('vla-admin-token');sessionStorage.removeItem('vla-admin-auth');throw new Error('Sesión vencida.');}if(!r.ok)throw new Error(d.detail||d.message||'Error');return d}async function login(e){e.preventDefault();try{const r=await fetch('/.netlify/functions/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({password:document.getElementById('password').value})});const d=await r.json();if(!r.ok||!d.success)throw new Error(d.message||'Contraseña incorrecta');sessionStorage.setItem('vla-admin-auth','true');sessionStorage.setItem('vla-admin-token',d.token);showApp()}catch(err){document.getElementById('login-error').textContent=err.message;document.getElementById('login-error').classList.remove('hidden')}}function showApp(){document.getElementById('login').classList.add('hidden');document.getElementById('app').classList.remove('hidden');loadAll()}function fmt(d){if(!d)return'—';try{return new Date(d).toLocaleString('es-VE',{timeZone:'America/Caracas'})}catch{return d}}async function loadAll(){try{const [j,s]=await Promise.all([adminFetch('/.netlify/functions/whatsapp-jobs?resource=jobs'),adminFetch('/.netlify/functions/whatsapp-jobs?resource=schedules')]);renderJobs(j.jobs||[]);renderSchedules(s.schedules||[])}catch(e){toast(e.message,true)}}function renderJobs(jobs){const pend=jobs.filter(j=>j.status==='Pendiente').length,run=jobs.filter(j=>j.status==='Ejecutando').length,err=jobs.filter(j=>j.status==='Error').length;document.getElementById('summary').innerHTML=`<div class='flex justify-between'><span>Pendientes:</span><b>${pend}</b></div><div class='flex justify-between'><span>Ejecutando:</span><b>${run}</b></div><div class='flex justify-between'><span>Errores:</span><b>${err}</b></div><div class='flex justify-between'><span>Última orden:</span><b>${jobs[0]?jobs[0].status:'—'}</b></div>`;document.getElementById('jobs-body').innerHTML=jobs.map(j=>`<tr class='border-b'><td class='p-2 font-semibold'>${j.jobId}<br><span class='text-xs text-slate-500'>${j.type}</span></td><td class='p-2 text-center'>${j.mode}</td><td class='p-2 text-center font-bold ${j.status==='Error'?'text-red-600':j.status==='Completado'?'text-green-600':'text-amber-600'}'>${j.status}</td><td class='p-2'>${fmt(j.scheduledAt)}</td><td class='p-2 text-right'>${j.sent||0}</td><td class='p-2 text-right'>${j.simulated||0}</td><td class='p-2 text-right'>${j.errors||0}</td><td class='p-2'>${j.status==='Pendiente'?`<button data-id='${j.jobId}' class='cancel bg-red-100 text-red-700 px-3 py-1 rounded-full text-xs'>Cancelar</button>`:''}</td></tr>`).join('')||'<tr><td colspan="8" class="p-4 text-center text-slate-500">Sin órdenes</td></tr>'}function renderSchedules(schedules){document.getElementById('schedules-body').innerHTML=schedules.map(s=>`<tr class='border-b'><td class='p-2 font-semibold'>${s.name}</td><td class='p-2 text-center'>${s.day}</td><td class='p-2 text-center'>${s.hour}</td><td class='p-2 text-center'>${s.mode}</td><td class='p-2 text-center'>${s.active?'✅':'—'}</td><td class='p-2'>${fmt(s.lastRun)}</td></tr>`).join('')||'<tr><td colspan="6" class="p-4 text-center text-slate-500">Sin programaciones</td></tr>'}document.getElementById('login-form').onsubmit=login;document.getElementById('refresh').onclick=loadAll;document.getElementById('create-job').onclick=async()=>{try{if(document.getElementById('job-mode').value==='Envío real'&&!confirm('Esto creará una orden de ENVÍO REAL para que el Mac mande WhatsApp. ¿Seguro?'))return;await adminFetch('/.netlify/functions/whatsapp-jobs',{method:'POST',body:JSON.stringify({action:'createJob',mode:document.getElementById('job-mode').value,force:document.getElementById('job-force').checked,avoidDuplicates:document.getElementById('job-avoid').checked,requestedBy:'Admin'})});toast('Orden creada.');loadAll()}catch(e){toast(e.message,true)}};document.getElementById('create-schedule').onclick=async()=>{try{await adminFetch('/.netlify/functions/whatsapp-jobs',{method:'POST',body:JSON.stringify({action:'createSchedule',name:`Recordatorio día ${document.getElementById('sch-day').value} ${document.getElementById('sch-hour').value}`,day:Number(document.getElementById('sch-day').value),hour:document.getElementById('sch-hour').value,mode:document.getElementById('sch-mode').value,active:document.getElementById('sch-active').checked})});toast('Programación guardada.');loadAll()}catch(e){toast(e.message,true)}};document.getElementById('run-scheduler').onclick=async()=>{try{const r=await adminFetch('/.netlify/functions/whatsapp-jobs?resource=scheduler-run');toast(`Revisión lista. Órdenes creadas: ${r.createdCount||0}`);loadAll()}catch(e){toast(e.message,true)}};document.getElementById('jobs-body').onclick=async e=>{const b=e.target.closest('.cancel');if(!b)return;try{await adminFetch('/.netlify/functions/whatsapp-jobs',{method:'POST',body:JSON.stringify({action:'cancelJob',jobId:b.dataset.id})});toast('Orden cancelada.');loadAll()}catch(err){toast(err.message,true)}};function applyTheme(t){document.documentElement.classList.toggle('dark',t==='dark');document.getElementById('theme').textContent=t==='dark'?'☀️ Claro':'🌙 Oscuro'}document.getElementById('theme').onclick=()=>{const n=document.documentElement.classList.contains('dark')?'light':'dark';localStorage.setItem('vla-wa-theme',n);applyTheme(n)};applyTheme(localStorage.getItem('vla-wa-theme')||'light');if(sessionStorage.getItem('vla-admin-auth')==='true'&&token())showApp();</script></body></html>
+<section class="bg-white rounded-2xl shadow p-5"><h2 class="text-xl font-bold mb-4">Programaciones</h2><div class="overflow-x-auto"><table class="min-w-full text-sm"><thead class="bg-slate-100"><tr><th class="p-2 text-left">Nombre</th><th class="p-2">Frecuencia</th><th class="p-2">Hora</th><th class="p-2">Modo</th><th class="p-2">Activo</th><th class="p-2">Última ejecución</th></tr></thead><tbody id="schedules-body"></tbody></table></div></section></div><div id="toast" class="fixed bottom-5 right-5 opacity-0 translate-y-6 toast text-white px-5 py-3 rounded-lg shadow-lg"></div>
